datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  phone         String?
  address       String?
  isAdmin       Boolean        @default(false)
  createdAt     DateTime       @default(now())
  cartItems     CartItem[]
  orders        Order[]
  subscriptions Subscription[]
}

model Product {
  id                    String      @id
  name                  String
  slug                  String      @unique
  description           String
  price                 Float
  images                String      // Comma-separated list of image paths
  flavor                String
  stock                 Int         @default(100)
  category              String
  subscriptionAvailable Boolean     @default(true)
  cartItems             CartItem[]
  orderItems            OrderItem[]
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  orderNumber     String      @unique
  paymentId       String?
  totalAmount     Float
  paymentStatus   String      // "Pending", "Paid", "Failed"
  orderStatus     String      // "Pending", "Confirmed", "Processing", "Shipped", "Out for Delivery", "Delivered", "Cancelled"
  shippingAddress String
  name            String
  phone           String
  email           String
  city            String
  state           String
  pincode         String
  trackingId      String?
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  productId    String
  quantity     Int
  productPrice Float
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Subscription {
  id          String   @id @default(uuid())
  userId      String
  planName    String   // e.g. "Aesthetic Stack", "Glow Stack", "Custom Stack"
  renewalDate DateTime
  status      String   // "Active", "Paused", "Skipped", "Cancelled"
  products    String   // JSON string e.g. '{"aesthetic-blueprint":6,"collagen-glow":6}'
  frequency   Int      @default(30) // in days
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}
